{
  "expo": {
    "name": "Todo & Diary",
    "slug": "ai-todo-diary",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a1a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aitododiary.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow access to your photos so you can attach them to tasks.",
        "NSCameraUsageDescription": "Allow access to your camera so you can take photos to attach to tasks.",
        "NSPhotoLibraryAddUsageDescription": "Allow saving captured photos so you can attach them to tasks."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a1a"
      },
      "package": "com.aitododiary.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6C63FF"
        }
      ],
      "expo-font"
    ],
    "sdkVersion": "54.0.0",
    "extra": {
      "eas": {
        "projectId": "6189c656-e1ce-4f2c-901e-9423789de026"
      }
    }
  }
}
